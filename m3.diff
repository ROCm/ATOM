+        architectures = getattr(model_config, "architectures", None)
+        if not architectures:
+            hf_config = getattr(model_config, "hf_config", None)
+            architectures = getattr(hf_config, "architectures", None)
+        return bool(
+            architectures
+            and architectures[0]
+            in {
